# App
NODE_ENV=development
PORT=3000
NODE_PORT=3000
SESSION_SECRET=replace-with-a-long-random-secret

# Preferred MongoDB setting (use this in Render)
MONGO_URI=mongodb+srv://<db_user>:<db_password>@<cluster_url>/<db_name>?retryWrites=true&w=majority&appName=Cluster0

# Legacy MongoDB pieces (optional fallback if MONGO_URI is not set)
DB_USER=
DB_PASSWORD=
DB_URL=
DB_NAME=

# Redis (Render Key Value / Redis)
REDIS_URL=redis://default:<password>@<host>:<port>

# Backward-compatible Redis variable
REDISCLOUD_URL=

# TMDB (set one of these)
TMDB_API_TOKEN=
TMDB_API_KEY=
TMDB_BASE_URL=https://api.themoviedb.org/3
